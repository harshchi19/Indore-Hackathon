# ────────────────────────────────────────────────────────────
# Verdant Backend — Environment Variables Template
# Copy this file to .env and fill in actual values.
# ────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
APP_NAME=Verdant Energy Platform
APP_VERSION=0.1.0

# Set to "production" for deployed environments
ENVIRONMENT=development

# Enable verbose logging (true/false)
DEBUG=false

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────
# Port the uvicorn server binds to.
# Render injects this automatically — do NOT set on Render.
# PORT=8000

# ── API ──────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# CORS allowed origins — JSON array of frontend URLs.
# Local dev:
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]
# Production example:
# ALLOWED_ORIGINS=["https://your-app.vercel.app","https://yourdomain.com"]

# ── MongoDB ──────────────────────────────────────────────────
# Local development:
# MONGODB_URI=mongodb://localhost:27017
# MongoDB Atlas (production):
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=verdant

# ── Redis ────────────────────────────────────────────────────
# Optional — used for caching / rate limiting.
# If not set, rate-limiting uses in-memory fallback.
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication ───────────────────────────────────────
# CRITICAL: Change this to a long random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-super-secret-jwt-key-for-dev
JWT_ALGORITHM=HS256

# Access token lifetime in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ────────────────────────────────────────────
# Max requests per IP per minute
RATE_LIMIT_PER_MINUTE=60

# ── Pricing Engine ───────────────────────────────────────────
# Interval between WebSocket price pushes (seconds)
PRICING_UPDATE_INTERVAL_SECONDS=10

# Base energy price (USD per kWh)
BASE_ENERGY_PRICE_KWH=0.12
