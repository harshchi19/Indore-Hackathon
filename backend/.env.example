# ────────────────────────────────────────────────────────────
# Verdant Backend — Environment Variables Template
# Copy this file to .env and fill in actual values.
# ────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
APP_NAME=Verdant Energy Platform
APP_VERSION=0.1.0

# Set to "production" for deployed environments
ENVIRONMENT=development

# Enable verbose logging (true/false)
DEBUG=false

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────
# Port the uvicorn server binds to.
# Render injects this automatically — do NOT set on Render.
# PORT=8000

# ── API ──────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# CORS allowed origins — JSON array of frontend URLs.
# Local dev:
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]
# Production example:
# ALLOWED_ORIGINS=["https://your-app.vercel.app","https://yourdomain.com"]

# ── MongoDB ──────────────────────────────────────────────────
# Local development:
# MONGODB_URI=mongodb://localhost:27017
# MongoDB Atlas (production):
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=verdant

# ── Redis ────────────────────────────────────────────────────
# Redis Cloud endpoint for rate limiting, caching, and account lockout.
# Format: redis://default:<password>@<host>:<port>
# Local development:
# REDIS_URL=redis://localhost:6379/0
# Redis Cloud (production):
REDIS_URL=redis://default:<YOUR_REDIS_PASSWORD>@redis-19177.c8.us-east-1-2.ec2.cloud.redislabs.com:19177

# ── JWT Authentication ───────────────────────────────────────
# CRITICAL: Change this to a long random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-super-secret-jwt-key-for-dev
JWT_ALGORITHM=HS256

# Access token lifetime in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ────────────────────────────────────────────
# Max requests per IP per minute
RATE_LIMIT_PER_MINUTE=60

# Use Redis for distributed rate limiting (true in production)
USE_REDIS_RATE_LIMIT=true

# ── Account Security ─────────────────────────────────────────
# Maximum failed login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in minutes
LOCKOUT_DURATION_MINUTES=15

# Enable security headers (X-Frame-Options, CSP, etc.)
ENABLE_SECURITY_HEADERS=true

# ── Pricing Engine ───────────────────────────────────────────
# Interval between WebSocket price pushes (seconds)
PRICING_UPDATE_INTERVAL_SECONDS=10

# Base energy price (USD per kWh)
BASE_ENERGY_PRICE_KWH=0.12

# ── AI Services ──────────────────────────────────────────────
# Groq (primary LLM – fast inference): https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini (fallback LLM): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_your_gemini_key_here

# Sarvam AI (Indian language TTS): https://app.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Neo4j Graph Database ──────────────────────────────────────
# Set ENABLE_NEO4J=true only when a real Neo4j instance is configured
ENABLE_NEO4J=false
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j
