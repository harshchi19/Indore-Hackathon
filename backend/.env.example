# Environment variables for Verdant Backend

# App Settings
APP_NAME=Verdant Backend - Part B
APP_VERSION=1.0.0
DEBUG=true

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=verdant

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Carbon Analytics
CO2_BASELINE_FACTOR_KG_PER_KWH=0.4
