# ────────────────────────────────────────────────────────────
# Verdant Frontend — Environment Variables Template
# Copy this file to .env and fill in actual values.
# All frontend env vars MUST start with VITE_ to be exposed to the browser.
# ────────────────────────────────────────────────────────────

# ── API Base URL ─────────────────────────────────────────────
# In LOCAL DEV: leave unset — the Vite proxy forwards /api/* to localhost:8000.
# In PRODUCTION (Vercel): leave unset — vercel.json rewrites /api/* to Render.
#
# Only set this if your backend is at a non-standard location:
# VITE_API_BASE_URL=https://your-backend.onrender.com/api/v1
