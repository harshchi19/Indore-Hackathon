# In local dev keep this unset (or relative) so all HTTP + WebSocket traffic
# routes through the Vite proxy (vite.config.ts → /api → localhost:8000).
# Setting an absolute http:// URL here causes pricingSocket.ts to bypass the
# proxy and connect cross-origin, which makes browser WebSockets fail.
# VITE_API_BASE_URL=http://localhost:8000/api/v1
